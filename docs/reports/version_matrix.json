    "standards_mapping_strategy": {
        "wcag_mapping": {
            "strategy": "tag-based (automated via axe-core rule tags)",
            "method": "Each axe-core rule has tags like wcag111, wcag143, wcag22aa. Lighthouse and IBM inherit via explicit mapping.",
            "data_sources": [
                "dequelabs/axe-core/doc/rule-descriptions.md (axe rule tags)",
                "GoogleChrome/lighthouse/core/audits/accessibility/ (LH audits reference axe rules)",
                "IBMa/equal-access/accessibility-checker-engine/src/v4/rules/ (IBM rules have WCAG_X_X_X metadata)"
            ],
            "automatable": true,
            "effort": "low (parsing structured metadata)"
        },
        "bitv_mapping": {
            "strategy": "embedding-based semantic matching + manual curation (hybrid)",
            "method_automated": {
                "name": "Embedding-based candidate generation",
                "tool": "sentence-transformers (multilingual distiluse model)",
                "process": [
                    "1. Generate embeddings for all BITV Prüfschritte descriptions (German)",
                    "2. Generate embeddings for all axe-core rule descriptions (English)",
                    "3. Calculate cosine similarity between each pair",
                    "4. Recommend top-3 candidate matches per Prüfschritt with confidence score",
                    "5. Output: config/bitv/bitv_axe_mapping_candidates.json (for human review)"
                ],
                "confidence_thresholds": {
                    "high_confidence": "similarity_score > 0.85 (likely correct, minimal review needed)",
                    "medium_confidence": "0.70-0.85 (needs human verification)",
                    "low_confidence": "< 0.70 (requires manual research)"
                },
                "script": "scripts/bootstrap_standards_data.py"
            },
            "method_curation": {
                "name": "Human review and finalization",
                "process": [
                    "1. Curator opens config/bitv/bitv_axe_mapping_candidates.json",
                    "2. For each Prüfschritt, reviews top-3 suggestions and confidence scores",
                    "3. Confirms correct match OR performs manual research if score is low",
                    "4. Adds notes explaining decision (especially for edge cases)",
                    "5. Creates final config/bitv/bitv_axe_mapping.json with verified mappings"
                ]
            },
            "advantages": [
                "Much faster than fully manual: embeddings narrow search space to top-3",
                "Multilingual: handles German descriptions with English rule descriptions",
                "Traceable: every decision is documented with score and curator notes",
                "Reproducible: same embedding model gives same candidates (versioned)"
            ],
            "limitations": [
                "Embedding quality depends on model choice and training data",
                "Some Prüfschritte may not have equivalent in any tool (MANUAL_ONLY)",
                "Requires domain expertise to verify edge cases",
                "Model must support German language"
            ],
            "maintenance": [
                "When BITV updates: re-run embeddings generator, curator reviews new candidates",
                "When axe-core updates: re-run embeddings generator, curator checks if mappings still valid",
                "When embedding model updates: regenerate all candidates (backwards compat check needed)"
            ]
        }
    }
